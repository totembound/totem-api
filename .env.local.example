# TotemBound Local Development Environment
# Copy to .env.local and customize as needed.
#
# NOTE: docker/docker-compose.yml loads this file into the totembound-api container via
# `env_file`, then OVERRIDES the host endpoints with in-container service names
# (DYNAMODB_ENDPOINT=dynamodb-local, COGNITO_ENDPOINT=cognito-local, SMTP_HOST=mailhog,
# AWS_REGION=us-west-2, APP_URL=http://localhost:3000). So the localhost values below are
# correct for running scripts on the HOST; the container substitutes the right hostnames.

# ============================================
# Server Configuration
# ============================================
PORT=3001
NODE_ENV=development
IS_LOCAL=true
# Consumer app on :3000, admin console (totem-admin) on :3002
CORS_ORIGIN=http://localhost:3000,http://localhost:3002

# ============================================
# DynamoDB Local
# ============================================
DYNAMODB_ENDPOINT=http://localhost:8000
DYNAMODB_USERS_TABLE=TotemBound-Users
DYNAMODB_TOTEMS_TABLE=TotemBound-Totems
DYNAMODB_CHALLENGES_TABLE=TotemBound-ChallengeProgress
DYNAMODB_EXPEDITIONS_TABLE=TotemBound-ExpeditionState
DYNAMODB_REWARDS_TABLE=TotemBound-RewardState
DYNAMODB_ACHIEVEMENTS_TABLE=TotemBound-AchievementProgress
DYNAMODB_SHOP_TABLE=TotemBound-Shop
DYNAMODB_REWARDS_CLAIMS_TABLE=TotemBound-RewardsClaims
DYNAMODB_TRANSACTIONS_TABLE=TotemBound-Transactions

# ============================================
# Cognito Local
# ============================================
COGNITO_USER_POOL_ID=local_totembound
COGNITO_CLIENT_ID=totembound-local-client
COGNITO_ENDPOINT=http://localhost:9229

# ============================================
# AWS (for LocalStack)
# ============================================
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=local
AWS_SECRET_ACCESS_KEY=local

# ============================================
# Stripe (Test Keys) — 8 vars total
# ============================================
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_test_key_here
# Printed by `stripe listen --forward-to localhost:3001/webhooks/stripe`.
# Changes every `stripe listen` session — update this then rebuild the api container.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Subscription tier prices (Stripe Dashboard → Products).
STRIPE_PRICE_PREMIUM=price_test_premium_id
STRIPE_PRICE_VIP=price_test_vip_id
# Gem-package prices — mapped by id in config/gem-packages.js
# (pkg_starter → STRIPE_PRICE_STARTER, etc.). Unset → that package falls back to dev mode.
STRIPE_PRICE_STARTER=price_test_starter_id
STRIPE_PRICE_POPULAR=price_test_popular_id
STRIPE_PRICE_BEST_VALUE=price_test_best_value_id
STRIPE_PRICE_ULTIMATE=price_test_ultimate_id

# ============================================
# Email (MailHog for local)
# ============================================
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@totembound.local
# App origin used to build links in emails (and Stripe success/cancel URLs).
# Host scripts: http://localhost:3000. (The container sets this itself.)
APP_URL=http://localhost:3000

# ============================================
# OAuth Social Login (optional)
# ============================================
# Google: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Twitch: https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=
# Discord: https://discord.com/developers/applications
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
OAUTH_REDIRECT_BASE=http://localhost:3000

# ============================================
# Feature Flags
# ============================================
FEATURE_EXPEDITIONS=true
FEATURE_ACHIEVEMENTS=true
FEATURE_SHOP=true
