{
    "name": "totem-api",
    "version": "0.14.0",
    "description": "TotemBound REST API - serverless backend for game actions and user management",
    "main": "index.js",
    "scripts": {
        "test": "jest --verbose",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage --watchAll=false",
        "test:ci": "jest --ci --coverage --watchAll=false --maxWorkers=2",
        "lint": "eslint src/**/*.js",
        "lint:fix": "eslint src/**/*.js --fix",
        "build": "node scripts/build.js",
        "package": "node scripts/package.js",
        "start:signup": "node scripts/local-dev.js signup",
        "start:premium": "node scripts/local-dev.js premium",
        "start:checkout": "node scripts/local-dev.js checkout",
        "clean": "rimraf dist node_modules/.cache",
        "prepare": "husky install",
        "dev:local": "IS_LOCAL=true nodemon --watch src src/local-server.js",
        "docker:up": "cd docker && docker compose up -d",
        "docker:down": "cd docker && docker compose down",
        "docker:logs": "cd docker && docker compose logs -f",
        "db:init": "node scripts/init-tables.js",
        "setup:local": "bash scripts/setup-local.sh",
        "token:generate": "node scripts/generate-test-token.js"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/totembound/totem-api.git"
    },
    "keywords": [
        "lambda",
        "serverless",
        "api-gateway",
        "game-api",
        "rest-api"
    ],
    "author": "TotemBound Team",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/totembound/totem-api/issues"
    },
    "homepage": "https://github.com/totembound/totem-api#readme",
    "dependencies": {
        "@aws-sdk/client-cognito-identity-provider": "^3.995.0",
        "@aws-sdk/client-dynamodb": "^3.995.0",
        "@aws-sdk/client-iot": "^3.995.0",
        "@aws-sdk/client-iot-data-plane": "^3.995.0",
        "@aws-sdk/client-ses": "^3.995.0",
        "@aws-sdk/client-ssm": "^3.995.0",
        "@aws-sdk/lib-dynamodb": "^3.995.0",
        "@aws-sdk/util-dynamodb": "^3.995.0",
        "@smithy/node-http-handler": "^4.4.9",
        "cors": "^2.8.6",
        "dotenv": "^16.3.1",
        "express": "^4.18.2",
        "helmet": "^7.0.0",
        "jsonwebtoken": "^9.0.3",
        "nodemailer": "^8.0.0",
        "obscenity": "^0.4.6",
        "serverless-http": "^3.2.0",
        "stripe": "^13.3.0",
        "ulid": "^3.0.2",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@aws-sdk/client-api-gateway": "^3.995.0",
        "@aws-sdk/client-cloudformation": "^3.995.0",
        "@aws-sdk/client-lambda": "^3.995.0",
        "@aws-sdk/client-s3": "^3.995.0",
        "@csstools/css-parser-algorithms": "^4.0.0",
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "aws4": "^1.13.2",
        "chalk": "^4.1.2",
        "concurrently": "^8.2.1",
        "cross-env": "^7.0.3",
        "eslint": "^8.47.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-jest": "^27.2.3",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-prettier": "^5.2.3",
        "husky": "^8.0.3",
        "jest": "^29.6.2",
        "jest-junit": "^17.0.0",
        "lint-staged": "^17.0.7",
        "lodash": "^4.17.21",
        "morgan": "^1.10.0",
        "nock": "^13.3.2",
        "node-cron": "^4.2.1",
        "nodemon": "^3.0.1",
        "prettier": "^3.5.3",
        "rimraf": "^5.0.1",
        "sinon": "^15.2.0",
        "socket.io": "^4.8.3",
        "swagger-jsdoc": "^6.2.8",
        "swagger-ui-express": "^5.0.1"
    },
    "jest": {
        "testEnvironment": "node",
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/**/templates/**",
            "!**/node_modules/**",
            "!src/app.js",
            "!src/lambda.js",
            "!src/local-server.js",
            "!src/routes/api-docs.js",
            "!src/types/api-responses.js",
            "!src/common/db-client.js",
            "!src/common/cognito-client.js",
            "!src/common/email.js",
            "!src/common/iot-publisher.js"
        ],
        "coverageThreshold": {
            "global": {
                "statements": 70,
                "branches": 60,
                "functions": 70,
                "lines": 70
            }
        },
        "testMatch": [
            "**/test/**/*.test.js"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/test/setup.js"
        ]
    },
    "lint-staged": {
        "*.js": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.json": [
            "prettier --write"
        ],
        "*.md": [
            "prettier --write"
        ]
    },
    "overrides": {
        "on-headers": "^1.1.0"
    },
    "engines": {
        "node": ">=22.0.0"
    }
}
