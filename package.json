{
    "name": "totem-api",
    "version": "1.0.0",
    "description": "TotemBound API for gasless transaction relay and user management",
    "main": "index.js",
    "scripts": {
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src/**/*.js",
        "lint:fix": "eslint src/**/*.js --fix",
        "build": "node scripts/build.js",
        "package": "node scripts/package.js",
        "deploy:dev": "node scripts/deploy.js dev",
        "deploy:staging": "node scripts/deploy.js staging",
        "deploy:prod": "node scripts/deploy.js prod",
        "start:relay": "node scripts/local-dev.js relay",
        "start:signup": "node scripts/local-dev.js signup",
        "start:premium": "node scripts/local-dev.js premium",
        "start:checkout": "node scripts/local-dev.js checkout",
        "start:all": "concurrently \"npm run start:relay\" \"npm run start:signup\" \"npm run start:premium\" \"npm run start:checkout\"",
        "clean": "rimraf dist node_modules/.cache",
        "prepare": "husky install"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/totembound/totem-api.git"
    },
    "keywords": [
        "blockchain",
        "lambda",
        "serverless",
        "api-gateway",
        "gasless",
        "transactions"
    ],
    "author": "TotemBound Team",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/totembound/totem-api/issues"
    },
    "homepage": "https://github.com/totembound/totem-api#readme",
    "dependencies": {
        "@aws-sdk/client-api-gateway": "^3.454.0",
        "@aws-sdk/client-cloudformation": "^3.454.0",
        "@aws-sdk/client-dynamodb": "^3.454.0",
        "@aws-sdk/client-lambda": "^3.454.0",
        "@aws-sdk/client-s3": "^3.454.0",
        "@aws-sdk/client-ses": "^3.454.0",
        "@aws-sdk/lib-dynamodb": "^3.454.0",
        "@aws-sdk/util-dynamodb": "^3.454.0",
        "dotenv": "^16.3.1",
        "ethers": "^6.7.1",
        "express": "^4.18.2",
        "helmet": "^7.0.0",
        "stripe": "^13.3.0",
        "uuid": "^9.0.0"
    },
    "devDependencies": {
        "@typescript-eslint/eslint-plugin": "^5.62.0",
        "@typescript-eslint/parser": "^5.62.0",
        "aws-sdk-mock": "^5.8.0",
        "chalk": "^4.1.2",
        "concurrently": "^8.2.1",
        "cross-env": "^7.0.3",
        "eslint": "^8.47.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-jest": "^27.2.3",
        "eslint-plugin-node": "^11.1.0",
        "eslint-plugin-prettier": "^5.2.3",
        "husky": "^8.0.3",
        "jest": "^29.6.2",
        "jest-junit": "^16.0.0",
        "lint-staged": "^14.0.0",
        "lodash": "^4.17.21",
        "morgan": "^1.10.0",
        "nock": "^13.3.2",
        "nodemon": "^3.0.1",
        "prettier": "^3.5.3",
        "rimraf": "^5.0.1",
        "serverless-http": "^3.2.0",
        "sinon": "^15.2.0",
        "supertest": "^6.3.3"
    },
    "jest": {
        "testEnvironment": "node",
        "collectCoverageFrom": [
            "src/**/*.js",
            "!src/**/templates/**",
            "!**/node_modules/**"
        ],
        "coverageThreshold": {
            "global": {
                "statements": 70,
                "branches": 60,
                "functions": 70,
                "lines": 70
            }
        },
        "testMatch": [
            "**/test/**/*.test.js"
        ],
        "setupFilesAfterEnv": [
            "<rootDir>/test/setup.js"
        ]
    },
    "lint-staged": {
        "*.js": [
            "eslint --fix",
            "prettier --write"
        ],
        "*.json": [
            "prettier --write"
        ],
        "*.md": [
            "prettier --write"
        ]
    },
    "engines": {
        "node": ">=18.0.0"
    }
}
